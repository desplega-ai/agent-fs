{
  "name": "agent-fs",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "typecheck": "tsc --build",
    "test": "bun test packages/*/src/",
    "test:coverage": "bun test --coverage packages/*/src/",
    "build": "bun build --compile packages/cli/src/index.ts --outfile dist/agentfs"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "bun-types": "^1.2.0"
  }
}
