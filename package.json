{
  "name": "agent-fs",
  "version": "0.5.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "typecheck": "tsc --build",
    "test": "bun test packages/*/src/",
    "test:coverage": "bun test --coverage packages/*/src/",
    "build": "cd packages/cli && bun run build:npm",
    "install-local": "bun run build && cd packages/cli && bun link",
    "uninstall-local": "bun remove -g @desplega.ai/agent-fs && rm -f ~/.bun/bin/agent-fs",
    "deploy:fly": "fly deploy -a agent-fs-taras"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0",
    "yaml": "^2.8.2",
    "zod-to-json-schema": "^3.25.1"
  }
}
