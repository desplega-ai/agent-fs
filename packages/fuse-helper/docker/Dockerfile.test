# Test harness for the agent-fs FUSE helper.
#
# Ubuntu 24.04 + fuse3 + Rust toolchain. Builds the helper inside the image
# from the bind-mounted source tree, then runs it against a stub Unix socket.
#
# Intended for Darwin developers (no native FUSE) and CI runners that allow
# --cap-add SYS_ADMIN --device /dev/fuse.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        build-essential \
        pkg-config \
        fuse3 \
        kmod \
        python3 \
        socat \
    && rm -rf /var/lib/apt/lists/*

# Install rustup + a pinned stable toolchain. Pinning keeps the image
# reproducible; bump as the host toolchain advances.
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
        sh -s -- -y --no-modify-path --profile minimal --default-toolchain 1.85.0 && \
    rustup component add rustfmt clippy

# Allow non-root mounts (the helper drops privileges in v1.x; for now run as
# root inside the container, which is fine since the container is disposable).
RUN echo "user_allow_other" >> /etc/fuse.conf

WORKDIR /work

# The repo is bind-mounted at /work at runtime; we don't COPY anything so the
# image stays slim and source edits don't invalidate the build cache.

# Default to running the in-container harness script.
ENTRYPOINT ["/work/packages/fuse-helper/docker/in-container-test.sh"]
