{
  "name": "@desplega.ai/agent-fs",
  "version": "0.1.5",
  "type": "module",
  "description": "Agent-first filesystem backed by S3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/desplega-ai/agent-fs.git"
  },
  "keywords": ["agent", "filesystem", "s3", "mcp", "cli"],
  "engines": {
    "bun": ">=1.2.0"
  },
  "bin": {
    "agent-fs": "dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build:npm": "bun build src/index.ts --outfile dist/cli.js --target bun --minify --external sqlite-vec --external node-llama-cpp --external @aws-sdk/client-s3 --external @google/genai --external openai --external commander --external diff --external drizzle-orm --external chonkie --external zod --external @modelcontextprotocol/sdk --external hono",
    "prepublishOnly": "bun run build:npm"
  },
  "optionalDependencies": {
    "sqlite-vec-darwin-arm64": "^0.1.6",
    "sqlite-vec-darwin-x64": "^0.1.6",
    "sqlite-vec-linux-arm64": "^0.1.6",
    "sqlite-vec-linux-x64": "^0.1.6",
    "sqlite-vec-windows-x64": "^0.1.6"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "@aws-sdk/client-s3": "^3.750.0",
    "@google/genai": "^1.45.0",
    "chonkie": "^0.3.0",
    "diff": "^8.0.3",
    "drizzle-orm": "^0.44.0",
    "node-llama-cpp": "^3.17.1",
    "openai": "^6.29.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.24.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.8"
  }
}
