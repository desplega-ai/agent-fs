# agent-fs production environment variables
# Copy to .env and fill in values, or set via `fly secrets set`

# ─── S3 Storage ───────────────────────────────────────────────
# Tigris (recommended on Fly.io) — these are auto-injected by `fly storage create`:
#   AWS_ENDPOINT_URL_S3, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
#   BUCKET_NAME, AWS_REGION
#
# BYOK (bring your own S3-compatible storage):
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_BUCKET=my-agent-fs-bucket
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=...
# S3_REGION=us-east-1
# S3_PROVIDER=aws

# ─── Server ──────────────────────────────────────────────────
# SERVER_PORT=7433
# SERVER_HOST=0.0.0.0

# ─── Embeddings (optional) ───────────────────────────────────
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=
# EMBEDDING_API_KEY=

# ─── Data Directory ──────────────────────────────────────────
# AGENT_FS_HOME=/data
