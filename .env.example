# agent-fs environment variables
# Copy to .env and fill in your values

# ── Core ──────────────────────────────────────────────
# Override default config directory (~/.agent-fs)
# AGENT_FS_HOME=~/.agent-fs

# ── Remote API (when connecting to a hosted agent-fs server) ──
# AGENT_FS_API_URL=https://your-server.example.com
# AGENT_FS_API_KEY=af_your_api_key_here

# ── Web App URL (enables appUrl field in op responses) ──
# AGENT_FS_APP_URL=https://live.agent-fs.dev

# ── S3 Storage ────────────────────────────────────────
# Generic S3 env vars (work with any S3-compatible provider)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=AKIA...
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_REGION=us-east-1
# S3_PROVIDER=minio

# Tigris / AWS env vars (take precedence over S3_* equivalents)
# AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
# AWS_ACCESS_KEY_ID=tid_...
# AWS_SECRET_ACCESS_KEY=tsec_...
# AWS_REGION=auto
# BUCKET_NAME=your-bucket

# ── Server ────────────────────────────────────────────
# SERVER_PORT or PORT (SERVER_PORT takes precedence)
# PORT=7433
# SERVER_PORT=7433
# SERVER_HOST or HOST (SERVER_HOST takes precedence)
# HOST=127.0.0.1
# SERVER_HOST=127.0.0.1
# AGENT_FS_RATE_LIMIT=1200

# ── Embeddings ────────────────────────────────────────
# Provider: "local", "openai", or "gemini"
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-...
